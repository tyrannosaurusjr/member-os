DJANGO_SETTINGS_MODULE=member_os.settings.development
DJANGO_SECRET_KEY=change-me-before-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

POSTGRES_DB=member_os
POSTGRES_USER=member_os
POSTGRES_PASSWORD=member_os
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

# Railway app services typically receive these values from the Postgres service:
# PGDATABASE=
# PGUSER=
# PGPASSWORD=
# PGHOST=
# PGPORT=
# RAILWAY_PUBLIC_DOMAIN=
# RAILWAY_PRIVATE_DOMAIN=

# Local export helpers:
# STRIPE_API_KEY=
# LUMA_API_KEY=
